#!/bin/bash

# --- Configuration ---
GEMINI_MODEL="gemini-2.5-flash"
GEMINI_PROMPT="Generate a concise, descriptive commit message based on the following diff:"
COMMIT_MSG_FILE="/tmp/GIT_COMMIT_MSG_TEMP.$$"

echo "⚙️ Staging all changes (git add .)..."
git add .

added_files=$(git diff --cached --name-only)
if [ -z "$added_files" ]; then
  echo "⚠️ No changes to commit. Aborting."
  exit 1
fi
echo "📄 Files staged for commit:"
echo "$added_files"
echo "---"

while true; do
  echo "🤖 Generating commit message using Gemini ($GEMINI_MODEL)..."
  
  commit_msg=$(git diff --cached | gemini --model "$GEMINI_MODEL" -p "$GEMINI_PROMPT")

  echo "$commit_msg" > "$COMMIT_MSG_FILE"

  echo "✏️ Opening Vim for editing the generated message..."
  vim "$COMMIT_MSG_FILE"
  
  FINAL_COMMIT_MSG=$(grep -vE '^\s*#|^\s*$' "$COMMIT_MSG_FILE")

  if [ -z "$FINAL_COMMIT_MSG" ]; then
    echo "❌ Commit message is empty after editing. Retrying generation..."
    continue
  fi
  
  echo "---"
  echo "📄 Final Commit Message (After Editing):"
  echo "--------------------------------------------------"
  echo "$FINAL_COMMIT_MSG"
  echo "--------------------------------------------------"
  
  read -r -p "🚀 Commit with this message? (y/N/R to Regenerate/Re-edit): " choice
  
  choice=$(echo "$choice" | tr '[:upper:]' '[:lower:]')

  if [[ "$choice" == "y" || "$choice" == "yes" ]]; then
    echo "✅ Committing changes..."
    git commit -F "$COMMIT_MSG_FILE"
    
    if [ $? -eq 0 ]; then
      echo "🎉 Commit successful!"
    else
      echo "❌ Commit failed!"
    fi
    rm -f "$COMMIT_MSG_FILE" 
    break
    
  elif [[ "$choice" == "r" || "$choice" == "regenerate" ]]; then
    echo "🔄 Regenerating commit message..."
    
  else
    echo "🛑 Aborting commit process."
    rm -f "$COMMIT_MSG_FILE" # Clean up temp file
    exit 1 # Exit the script
  fi
done
