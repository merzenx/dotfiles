#!/bin/bash

GEMINI_MODEL="gemini-2.5-flash"
GEMINI_PROMPT="Generate a concise, descriptive git commit message in plain text only. No markdown, no bullets, no formatting."

COMMIT_MSG_FILE=$(mktemp /tmp/GIT_COMMIT_MSG_XXXXXX)
trap "rm -f $COMMIT_MSG_FILE" EXIT

EDITOR_CMD=${EDITOR:-vim}

strip_markdown() {
  sed \
    -e 's/^#\+ *//' \
    -e 's/^[-*+] *//' \
    -e 's/`//g' \
    -e 's/\*\*//g' \
    -e 's/\*//g' \
    -e 's/_//g' \
    -e 's/\[//g' \
    -e 's/\]//g'
}

echo "Staging all changes (git add .)..."
git add .

added_files=$(git diff --cached --name-only)
if [ -z "$added_files" ]; then
  echo "No changes to commit. Aborting."
  exit 0
fi

echo "Files staged for commit:"
echo "$added_files"
echo "---"

REGENERATE=true

while true; do
  if $REGENERATE; then
    echo "Generating commit message using Gemini ($GEMINI_MODEL)..."

    commit_msg=$(
      git diff --cached \
      | gemini --model "$GEMINI_MODEL" -p "$GEMINI_PROMPT" \
      | strip_markdown \
      | sed '/^$/d' \
      | head -n 1
    )

    echo "$commit_msg" > "$COMMIT_MSG_FILE"
    REGENERATE=false
  fi

  echo "Opening $EDITOR_CMD for editing the message..."
  "$EDITOR_CMD" "$COMMIT_MSG_FILE"

  FINAL_COMMIT_MSG=$(grep -vE '^\s*#|^\s*$' "$COMMIT_MSG_FILE")

  if [ -z "$FINAL_COMMIT_MSG" ]; then
    echo "Commit message is empty after editing. Regenerating..."
    REGENERATE=true
    continue
  fi

  echo "---"
  echo "Final Commit Message:"
  echo "--------------------------------------------------"
  echo "$FINAL_COMMIT_MSG"
  echo "--------------------------------------------------"

  read -r -p "Commit with this message? (y/N/R to Regenerate/E to Re-edit): " choice
  choice=$(echo "$choice" | tr '[:upper:]' '[:lower:]')

  if [[ "$choice" == "y" || "$choice" == "yes" ]]; then
    echo "Committing changes..."
    git commit -F "$COMMIT_MSG_FILE"

    if [ $? -eq 0 ]; then
      echo "Commit successful!"
    else
      echo "Commit failed!"
    fi
    break

  elif [[ "$choice" == "r" || "$choice" == "regenerate" ]]; then
    REGENERATE=true

  elif [[ "$choice" == "e" || "$choice" == "re-edit" ]]; then
    continue

  else
    echo "Aborting commit process."
    exit 1
  fi
done
