#!/bin/bash

PROMPT="Generate exactly one git commit message line using Conventional Commits. Format: feat(scope): concise imperative summary. Scope must be a short lowercase noun inferred from the diff. Avoid vague words. Max 72 characters. Plain text only. Output nothing else."

EDITOR_CMD=${EDITOR:-vim}

git add .

if git diff --cached --quiet; then
  echo "No changes to commit."
  exit 0
fi

commit_msg=$(git diff --cached | opencode run "$PROMPT" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')

echo "Proposed commit message:"
echo "--------------------------------"
echo "$commit_msg"
echo "--------------------------------"

read -r -p "Edit message? (y/N): " edit
edit=$(echo "$edit" | tr '[:upper:]' '[:lower:]')

if [[ "$edit" == "y" || "$edit" == "yes" ]]; then
  tmp=$(mktemp)
  echo "$commit_msg" > "$tmp"
  "$EDITOR_CMD" "$tmp"
  commit_msg=$(cat "$tmp")
  rm -f "$tmp"
fi

[ -z "$commit_msg" ] && echo "Empty commit message. Aborted." && exit 1

git commit -m "$commit_msg"
