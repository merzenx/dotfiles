#!/bin/bash

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

error() {
    echo -e "${RED}❌ Error: $1${NC}" >&2
    exit 1
}

success() {
    echo -e "${GREEN}✓ $1${NC}"
}

info() {
    echo -e "${BLUE}ℹ $1${NC}"
}

warning() {
    echo -e "${YELLOW}⚠ $1${NC}"
}

if ! git rev-parse --git-dir > /dev/null 2>&1; then
    error "Not in a git repository"
fi

MAIN_BRANCH="${1:-main}"

if ! git rev-parse --verify "$MAIN_BRANCH" > /dev/null 2>&1; then
    info "Branch '$MAIN_BRANCH' not found, trying master..."
    MAIN_BRANCH="master"
    
    if ! git rev-parse --verify "$MAIN_BRANCH" > /dev/null 2>&1; then
        error "Main branch not found. Specify branch name: ./git-sync.sh [branch_name]"
    fi
fi

info "Using main branch: $MAIN_BRANCH"

CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

if [ "$CURRENT_BRANCH" = "$MAIN_BRANCH" ]; then
    warning "Already on $MAIN_BRANCH. Pulling latest updates..."
    git pull origin "$MAIN_BRANCH"
    success "Updated $MAIN_BRANCH"
    exit 0
fi

info "Current branch: $CURRENT_BRANCH"

if ! git diff-index --quiet HEAD --; then
    error "Uncommitted changes detected. Please commit or stash first"
fi

info "Fetching latest updates..."
git fetch origin

info "Syncing $CURRENT_BRANCH from $MAIN_BRANCH..."

git rebase "origin/$MAIN_BRANCH"

info "Pushing changes..."
git push origin "$CURRENT_BRANCH" --force-with-lease

success "✨ Sync completed! Branch '$CURRENT_BRANCH' is now in sync with '$MAIN_BRANCH'"
