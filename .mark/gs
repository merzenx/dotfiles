#!/bin/bash

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

error() {
    echo -e "${RED}❌ Error: $1${NC}" >&2
    exit 1
}

success() {
    echo -e "${GREEN}✓ $1${NC}"
}

info() {
    echo -e "${BLUE}ℹ $1${NC}"
}

warning() {
    echo -e "${YELLOW}⚠ $1${NC}"
}

if ! git rev-parse --git-dir > /dev/null 2>&1; then
    error "Not in a git repository"
fi

MAIN_BRANCH="${1:-main}"

if ! git rev-parse --verify "$MAIN_BRANCH" > /dev/null 2>&1; then
    MAIN_BRANCH="master"
    if ! git rev-parse --verify "$MAIN_BRANCH" > /dev/null 2>&1; then
        error "Main branch not found."
    fi
fi

info "Using main branch: $MAIN_BRANCH"

CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

if [ "$CURRENT_BRANCH" = "$MAIN_BRANCH" ]; then
    warning "Already on $MAIN_BRANCH. Pulling updates..."
    git pull origin "$MAIN_BRANCH"
    success "Updated $MAIN_BRANCH"
    exit 0
fi

HAS_CHANGES=false
if ! git diff-index --quiet HEAD --; then
    info "Saving local changes with stash..."
    git stash push -m "Auto-stash before sync"
    HAS_CHANGES=true
fi

info "Fetching and Rebasing on $MAIN_BRANCH..."

git fetch origin "$MAIN_BRANCH"

if ! git rebase "origin/$MAIN_BRANCH"; then
    warning "Conflict detected! Please resolve conflicts manually."
    exit 1
fi

info "Pushing safely..."
git push origin "$CURRENT_BRANCH" --force-with-lease

if [ "$HAS_CHANGES" = true ]; then
    info "Restoring local changes..."
    git stash pop
fi

success "✨ Sync completed! '$CURRENT_BRANCH' is now updated."
