// keybinds managed by niri-settings. Consider moving existing binds here.
binds {
    Mod+E { spawn "nautilus"; }
    // Mod+B hotkey-overlay-title="Google Chrome" { spawn "google-chrome-stable"; }
    Mod+B hotkey-overlay-title="Zen Browser" { spawn "zen-browser"; }
    Mod+C hotkey-overlay-title="QML Dialog" { spawn "qs" "-p" "/home/mark/projects/dev-tools/windows_dialog.qml"; }

    // === Hyprland-like split keybinds ===
    // Split horizontal (move window left/right = new column) - already on Mod+Shift+H/L
    // Split vertical (consume into column = stack in same column like Hyprland's splitv)
    Mod+Shift+Z { consume-window-into-column; }
    Mod+Z { expel-window-from-column; }
}
